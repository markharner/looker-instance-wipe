# Copy to looker.ini and fill in your credentials.
# Alternatively, pass credentials via CLI flags or environment variables:
#   LOOKER_BASE_URL, LOOKER_CLIENT_ID, LOOKER_CLIENT_SECRET

[Looker]
# Base URL of the Looker instance (no trailing slash)
base_url=https://yourcompany.looker.com

# API3 credentials — Admin > Users > Edit user > API3 Keys
client_id=your_client_id
client_secret=your_client_secret

# API version (leave as 4.0)
api_version=4.0

# Set to false only if using a self-signed cert
verify_ssl=true
